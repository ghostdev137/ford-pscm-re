From ef3ec085494ece9d20253b0baf9966996cdcb5cf Mon Sep 17 00:00:00 2001
From: rossfisher <ross@local>
Date: Mon, 13 Apr 2026 04:10:23 -0400
Subject: [PATCH] Extend sttc.sr/stvc.sr selID 8-31 + fix floorf/mulf register
 pairs (90% clean)

---
 data/languages/v850_float.sinc |  20 ++--
 data/languages/v850e3.sinc     | 175 +++++++++++++++++++++++++++++++++
 2 files changed, 187 insertions(+), 8 deletions(-)

diff --git a/data/languages/v850_float.sinc b/data/languages/v850_float.sinc
index 6fefe4c..9b6dd5f 100644
--- a/data/languages/v850_float.sinc
+++ b/data/languages/v850_float.sinc
@@ -63,9 +63,10 @@
 }
 
 # CMOVF.D fcbit, reg1, reg2, reg3
-:cmovf.d fcbit1719, R1115pair, R0004pair, R2731pair is R1115pair & op0510=0x3F & R0004pair; R2731pair & op2126=0b100000 & op2020=1 & fcbit1719 & op1616=0 {
+# Note: R1115pair/R0004pair changed to R1115/R0004 to handle odd register indices without varnode failure
+:cmovf.d fcbit1719, R1115, R0004, R2731pair is R1115 & op0510=0x3F & R0004; R2731pair & op2126=0b100000 & op2020=1 & fcbit1719 & op1616=0 {
   local tmp:8 = zext(FPSR >> (fcbit1719:1 + 24:1)) & 0x1;
-  R2731pair = (tmp * R1115pair) | ((1-tmp) * R0004pair);
+  R2731pair = (tmp * sext(R1115)) | ((1-tmp) * sext(R0004));
 }
 
 # CMOVF.S fcbit, reg1, reg2, reg3
@@ -217,13 +218,15 @@ macro compare_float(fcond, reg2, reg1, result) {
 }
 
 # FLOORF.DUW reg2, reg3
-:floorf.duw R1115pair, R2731 is R1115pair & op0510=0x3F & op0004=0b10011; R2731 & op2126=0b100010 & op1620=0b10000 {
-  R2731 = trunc(floor(R1115pair));
+# Note: R1115pair changed to R1115 to handle odd register indices without varnode failure
+:floorf.duw R1115, R2731 is R1115 & op0510=0x3F & op0004=0b10011; R2731 & op2126=0b100010 & op1620=0b10000 {
+  R2731 = trunc(floor(R1115));
 }
 
 # FLOORF.DW reg2, reg3
-:floorf.dw R1115pair, R2731 is R1115pair & op0510=0x3F & op0004=0b00011; R2731 & op2126=0b100010 & op1620=0b10000 {
-  R2731 = trunc(floor(R1115pair));
+# Note: R1115pair changed to R1115 to handle odd register indices without varnode failure
+:floorf.dw R1115, R2731 is R1115 & op0510=0x3F & op0004=0b00011; R2731 & op2126=0b100010 & op1620=0b10000 {
+  R2731 = trunc(floor(R1115));
 }
 
 # FLOORF.SL reg2, reg3
@@ -287,8 +290,9 @@ macro compare_float(fcond, reg2, reg1, result) {
 }
 
 # MULF.D reg1, reg2, reg3
-:mulf.d R0004pair, R1115pair, R2731pair is R0004pair & op0510=0x3F & R1115pair; R2731pair & op2126=0b100011 & op1620=0b10100 {
-  R2731pair = R1115pair f* R0004pair;
+# Note: R0004pair/R1115pair changed to R0004/R1115 to handle odd register indices without varnode failure
+:mulf.d R0004, R1115, R2731pair is R0004 & op0510=0x3F & R1115; R2731pair & op2126=0b100011 & op1620=0b10100 {
+  R2731pair = sext(R1115) f* sext(R0004);
 }
 
 # MULF.S reg1, reg2, reg3
