 }
 
diff --git a/data/languages/v850_data_manipulation.sinc b/data/languages/v850_data_manipulation.sinc
index fd6d558..74b1700 100644
--- a/data/languages/v850_data_manipulation.sinc
+++ b/data/languages/v850_data_manipulation.sinc
@@ -49,16 +49,16 @@ macro shift_left (res, _val, _shift) {
 
 
 # SHR imm5, reg2
-:shr op0004, r1115 is op0510=0x14 & op0004 & r1115 {
-	shift_right_u (r1115, r1115, op0004);
+:shr op0004, R1115 is op0510=0x14 & op0004 & R1115 {
+	shift_right_u (R1115, R1115, op0004);
 }
 # SAR imm5, reg2
