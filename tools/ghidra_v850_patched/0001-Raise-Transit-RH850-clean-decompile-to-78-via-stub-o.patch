 }
 # SHL imm5, reg2
-:shl op0004, r1115 is op0510=0x16 & op0004 & r1115 {
-	shift_left (r1115, r1115, op0004);
+:shl op0004, R1115 is op0510=0x16 & op0004 & R1115 {
+	shift_left (R1115, R1115, op0004);
 }
 
 # SHR reg1, reg2
@@ -87,7 +87,7 @@ macro shift_left (res, _val, _shift) {
 }
 
 # BSW reg2, reg3
-:bsw R1115, R2731 is op0010=0x7E0 & R1115; op1626=0x340 & R2731 {
+:bsw R1115, R2731 is op0510=0x3F & R1115; op2126=0x1A & op1718=0b00 & R2731 {
 	local x0 = R1115[0,8];
 	local x1 = R1115[8,8];
 	local x2 = R1115[16,8];
@@ -97,7 +97,7 @@ macro shift_left (res, _val, _shift) {
 	set_C ((x0 == 0) || (x1 == 0) || (x2 == 0) || (x3 == 0));
 }
 # BSH reg2, reg3
-:bsh R1115, R2731 is op0010=0x7E0 & R1115; op1626=0x342 & R2731 {
+:bsh R1115, R2731 is op0510=0x3F & R1115; op2126=0x1A & op1718=0b01 & R2731 {
 	local x0 = R1115[0,8];
 	local x1 = R1115[8,8];
 	local x2 = R1115[16,8];
@@ -107,7 +107,7 @@ macro shift_left (res, _val, _shift) {
 	set_C ((x0 == 0) || (x1 == 0));
 }
 # HSW reg2, reg3
-:hsw R1115, R2731 is op0010=0x7E0 & R1115; op1626=0x344 & R2731 {
+:hsw R1115, R2731 is op0510=0x3F & R1115; op2126=0x1A & op1718=0b10 & R2731 {
 	# reg3 = reg2(15:0) || reg2(31:16)
 	local x0 = R1115[0,16];
 	local x1 = R1115[16,16];
@@ -116,7 +116,7 @@ macro shift_left (res, _val, _shift) {
 	set_C ((x0 == 0) || (x1 == 0));
 }
 # HSH reg2, reg3
-:hsh R1115, R2731 is op0010=0x7E0 & R1115; op1626=0x346 & R2731 {
+:hsh R1115, R2731 is op0510=0x3F & R1115; op2126=0x1A & op1718=0b11 & R2731 {
