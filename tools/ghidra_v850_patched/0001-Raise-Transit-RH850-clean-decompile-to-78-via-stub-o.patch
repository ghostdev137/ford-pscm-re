@@ -49,11 +49,11 @@ cc1720: "gt"	is op1720=0xF		{ tmp:1 = !($(PSW_S) ^^ $(PSW_OV) || $(PSW_Z));	expo
 }
 
 # SETF cond, reg2
-:setf^cc0003 R1115 is op0410=0x7E & cc0003 & R1115; op1631=0 {
+:setf^cc0003 R1115 is op0410=0x7E & cc0003 & R1115; op2126=0x00 {
 	R1115 = zext(cc0003);
 }
 # SASF cccc, reg2
-:sasf^cc0003 R1115 is op0410=0x7E & cc0003 & R1115; op1631=0x0200 {
+:sasf^cc0003 R1115 is op0410=0x7E & cc0003 & R1115; op2126=0x10 {
